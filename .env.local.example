# Copy this to .env.local (and add the same keys in your Vercel project's
# Environment Variables for production). Every feature below works without
# its key — it just falls back to a clearly-labelled demo/local-only mode
# until you add it.

# ── Already configured (yours) — persistent earnings ledger ──────────────
# Supabase project. Run supabase_schema.sql once in the SQL Editor first.
NEXT_PUBLIC_SUPABASE_URL=https://zvasucmfgwddhxymfqgc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Ustaad's real AI brain ────────────────────────────────────────────────
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Real Hum-to-Match song recognition (AudD) ────────────────────────────
# Free tier token: https://dashboard.audd.io
